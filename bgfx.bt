        [getCountValue(0)]; \
        FSeek(getOffsetValue(1) + 8); /* after 64-bit pointer */ \
    } \
    popOffset(); \
    popOffset(); \
    popCount();


#define TSTRUCT_PTR_ARRAY_PTR_START \
    pushCount(ReadUInt(FTell())); \
    FSkip(4); \
    pushOffset(FTell()); \
    pushOffset(ReadUInt64(FTell())); \
    FSkip(8); \
    if (getOffsetValue(0) != 0 && getCountValue(0) != 0) \
