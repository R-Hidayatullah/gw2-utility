            popLoopIndex(); \
            pushLoopIndex(sTempLoopIndex); \
        } \
        popLoopIndex(); \
        FSeek(getOffsetValue(1) + 8); \
    } \
    popOffset(); \
    popOffset(); \
    popCount();


#define TPTR_START \
